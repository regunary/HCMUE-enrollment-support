# Copy to .env.local (gitignored) and adjust.
# Django API origin — no trailing slash (Docker publishes BE on host 8021 — see docker-compose BACKEND_HOST_PORT).
VITE_API_BASE_URL=http://localhost:8021
# true = in-memory mock; false = call VITE_API_BASE_URL using paths in src/api/endpoints.ts
VITE_USE_MOCK=true
