# Copy to `.env` next to docker-compose.yml and adjust.
# Production: set SECRET_KEY to a long random value (e.g. openssl rand -hex 32).

SECRET_KEY=change-me-before-deploy

POSTGRES_DB=hcmue_enrollment_support
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DEBUG=False

NGINX_PORT=5032

# Frontend build (passed as Docker build args)
VITE_API_BASE_URL=/api
VITE_USE_MOCK=false
